generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model storage {
  id            Int      @id @default(autoincrement())
  createdAt     DateTime
  updatedAt     DateTime
  downloadCount Int
  target        String
  status        String
  basePath      String   @unique
  headers       Json?
}

model target {
  id        Int     @id @default(autoincrement())
  code      String
  host      String?
  userAgent String?
  https     Boolean @default(false)
  enabled   Boolean @default(true)
}
